# =============================================================================
# sonder-engram — example environment config
# =============================================================================
# Copy this file to `.env` and fill in your real key(s):
#     cp .env.example .env
#
# SAFE TO COMMIT: this file (placeholders only).
# NEVER COMMIT `.env` (it holds real keys) — make sure `.env` is in .gitignore.
#
# Cognee reads these as environment variables (pydantic BaseSettings; it also
# auto-loads a `.env` in the working directory). Var name == config field name
# uppercased, so LLM_PROVIDER -> llm_provider, etc.
# =============================================================================

# -----------------------------------------------------------------------------
# LLM — default: DeepSeek (cheap, OpenAI-compatible)
# -----------------------------------------------------------------------------
# DeepSeek isn't a named Cognee provider, so we use the generic "custom" adapter,
# which is built for OpenAI-compatible endpoints and defaults to instructor
# json_mode (the right mode for DeepSeek — do NOT use tool/function-calling mode).
LLM_PROVIDER=custom
LLM_MODEL=openai/deepseek-chat          # openai/ prefix + explicit endpoint = unambiguous OpenAI-compatible route
LLM_ENDPOINT=https://api.deepseek.com/v1
LLM_API_KEY=your-deepseek-api-key-here

# Optional. json_mode is already the custom-adapter default. If DeepSeek wraps
# JSON in ``` fences and instructor fails to parse, switch to markdown-JSON mode:
# LLM_INSTRUCTOR_MODE=markdown_json_mode

# -----------------------------------------------------------------------------
# EMBEDDINGS — default: fastembed (local, no key, no cost)
# -----------------------------------------------------------------------------
# DeepSeek has no embeddings endpoint, and Cognee needs an embedder as well as an
# LLM. fastembed runs a small model locally (no API key). Requires:
#     uv pip install fastembed        (downloads model weights on first use)
# EMBEDDING_MODEL must be a fastembed-supported model; all-MiniLM-L6-v2 = 384 dims.
EMBEDDING_PROVIDER=fastembed
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSIONS=384
# Alternative fastembed model (also 384 dims):
# EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# -----------------------------------------------------------------------------
# Runtime toggles
# -----------------------------------------------------------------------------
# Multi-tenant access control is ON by default, which scopes dataset-name lookups
# to the current user. For the single-user local demo, turn it off so
# datasets=["npc__..."] resolves simply.
ENABLE_BACKEND_ACCESS_CONTROL=false
# Session memory is ON by default (set CACHING=false to disable). Leave as-is.

# =============================================================================
# SWITCH TO OPENAI (when you fund it) — uncomment this block, comment the DeepSeek
# LLM block above. This is the only change needed in code terms; the SDK is
# provider-agnostic.
# =============================================================================
# LLM_PROVIDER=openai
# LLM_MODEL=openai/gpt-5-mini
# LLM_ENDPOINT=                         # blank -> OpenAI's default endpoint
# LLM_API_KEY=your-openai-api-key-here
# # Clear the DeepSeek-specific instructor mode so OpenAI uses its reliable default:
# # (leave LLM_INSTRUCTOR_MODE unset)
#
# # Optional: move embeddings to OpenAI too (or keep fastembed — it's free).
# EMBEDDING_PROVIDER=openai
# EMBEDDING_MODEL=openai/text-embedding-3-large   # 3072 dims (use -small for 1536)
# EMBEDDING_DIMENSIONS=3072
#
# !!! RE-EMBED REQUIRED !!!
# Changing the embedding model/provider changes the vector space (and here the
# dimension: 384 -> 3072), so existing stored vectors are NOT reusable. You must
# rebuild the store before querying old memories:
#     import cognee, asyncio
#     asyncio.run(cognee.prune.prune_data())
#     asyncio.run(cognee.prune.prune_system(metadata=True))
#     # then re-ingest / re-run remember() so memories are re-embedded
# New data written after the switch is fine; only previously-persisted graphs
# need rebuilding. (Swapping ONLY the LLM, not embeddings, needs no re-embed.)

# =============================================================================
# OTHER PROVIDERS
# Cognee has native adapters for: openai, ollama, anthropic, gemini, mistral,
# azure, bedrock, llama_cpp (+ "custom" for any OpenAI-compatible endpoint).
# Free + reliable extraction alt: Gemini (Google AI Studio key is free) —
#   LLM_PROVIDER=gemini ; LLM_MODEL=gemini/gemini-2.0-flash ; LLM_API_KEY=...
# =============================================================================
